VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- API base URL ---
# In dev: leave empty so fetches go to "/v1/..." same-origin; Vite's dev proxy
# forwards them to VITE_API_PROXY_TARGET server-side (no browser CORS).
# In prod (Vercel): set this to the absolute backend URL. Browser CORS DOES
# apply — Dev 1's backend MUST allow-list the deployment domain.
#   e.g. https://api.veralithai.com
VITE_API_URL=

# Dev-only: where Vite's `/v1/*` proxy forwards in `pnpm dev`. Ignored in prod.
VITE_API_PROXY_TARGET=http://localhost:8000

# 'true' = in-memory fixtures (development), 'false' = hit VITE_API_URL.
# Production deploys should be 'false'.
VITE_USE_MOCK_API=true
