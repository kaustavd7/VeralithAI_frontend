VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Base URL for the Veralith API. Leave empty in dev — Vite proxies /v1/* to localhost:8000.
# In prod, set to e.g. https://api.veralithai.com.
VITE_API_URL=

# Mock layer for Phase 1: 'true' = in-memory fixtures, 'false' = real backend
VITE_USE_MOCK_API=true
